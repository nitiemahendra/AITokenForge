# ============================================================
# TokenForge — Production .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
ENV/
env/
.env/
env.bak/
venv.bak/

# ── Testing & Coverage ───────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml
.tox/
.nox/

# ── Type checkers & Linters ──────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# ── Build artifacts ───────────────────────────────────────────
*.so
*.dylib
*.dll

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Environment & Secrets — NEVER COMMIT ─────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test
*.secret
*_secret*
secrets/
credentials/
*.pem
*.key
*.cert
*.p12
*.pfx

# ── Logs — may contain user prompt data ──────────────────────
*.log
logs/
backend_server.log
frontend.log
frontend-err.log

# ── Database files ────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── ML Model weights — use `ollama pull` instead ─────────────
*.bin
*.safetensors
*.gguf
*.ggml
*.pt
*.pth
*.pkl
*.h5
.cache/
models/weights/

# ── AI / prompt artifacts ────────────────────────────────────
prompt_cache/
optimization_cache/
token_cache/
embedding_cache/
*.embeddings

# ── Docker local state ────────────────────────────────────────
.docker/

# ── IDE ───────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Website (deployed separately via Netlify) ────────────────
website/node_modules/
website/.next/
website/out/
website/.netlify/

# ── Benchmarks output ────────────────────────────────────────
benchmarks/results/

# ── Claude Code assistant ────────────────────────────────────
.claude/

# ── Release artifacts ────────────────────────────────────────
*.zip
*.tar.gz
*.whl
