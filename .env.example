# ─── TokenForge Environment Configuration ────────────────────────────────────
# Copy to .env and customize.

# LLM Adapter: "ollama" | "mock"
LLM_ADAPTER=ollama

# Ollama settings (must be running: `ollama serve`)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_TIMEOUT=120

# Semantic embedding model (downloaded automatically from HuggingFace)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu   # cpu | cuda | mps

# Logging
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
JSON_LOGS=false         # true for production/Docker

# CORS (comma-separated, no spaces between entries)
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Optimization defaults
DEFAULT_MODE=balanced
MAX_PROMPT_LENGTH=100000
SEMANTIC_SIMILARITY_THRESHOLD=0.85

# ─── Optional: Frontend (Vite) ─────────────────────────────────────────────
# VITE_API_URL=http://localhost:8000
